# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Ruxsat berilgan userlar (vergul bilan ajrating)
ALLOWED_USER_IDS=123456789,987654321

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Upstash Redis ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Upstash QStash ─────────────────────────────────────────────────────────────
# https://console.upstash.com/qstash → API Keys
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxxxxxxxxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxxxxxxxxxx

# ── App URL ────────────────────────────────────────────────────────────────────
# Production: Cloud Run Service URL (masalan, https://shahriyor-assist-xxx-uc.a.run.app)
# Local test uchun: ngrok URL (masalan, https://abc123.ngrok.io)
APP_URL=https://your-service-xxx-uc.a.run.app
