# ════════════════════════════════════════════════════════════════════════════════
# LOCAL DEV: faqat [MAJBURIY] deb belgilangan varlarni to'ldiring
#            npm run dev:poll — ngrok shart emas, webhook kerak emas
#
# PRODUCTION: barchasi majburiy (Cloud Run Environment Variables ga qo'shing)
# ════════════════════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here              # [MAJBURIY] @BotFather dan

# Ruxsat berilgan Telegram user ID lari (vergul bilan)
# O'z ID ni bilish: @userinfobot ga /start yozing
ALLOWED_USER_IDS=123456789                          # [MAJBURIY] o'z ID ingizni kiriting

# Webhook xavfsizlik kaliti — faqat production uchun (dev:poll da kerak emas)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here     # [production majburiy]

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here             # [MAJBURIY] aistudio.google.com

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io  # [MAJBURIY]
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here    # [MAJBURIY]

# ── Upstash QStash — eslatmalar uchun (dev:poll da ishlaydi, lekin optional) ──
# https://console.upstash.com/qstash → API Keys
QSTASH_TOKEN=your_qstash_token_here                 # [production majburiy]
QSTASH_CURRENT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxx     # [production majburiy]
QSTASH_NEXT_SIGNING_KEY=sig_xxxxxxxxxxxxxxxx        # [production majburiy]

# ── App URL — faqat production (QStash reminder callbacki uchun) ──────────────
# Cloud Run: https://shahriyor-assist-xxx-uc.a.run.app
APP_URL=https://your-service-xxx-uc.a.run.app       # [production majburiy]

# ── OpenWeatherMap — ixtiyoriy (yo'q bo'lsa ob-havo ishlamaydi) ───────────────
# https://openweathermap.org/api → Free API key
# OPENWEATHERMAP_API_KEY=your_key_here

# ── Telegram MTProto — ixtiyoriy (kontaktga xabar yuborish uchun) ─────────────
# scripts/generate-session.mjs ni ishga tushiring
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
# TELEGRAM_SESSION=1BVtsOK...

# ── Google Calendar & Sheets — ixtiyoriy ──────────────────────────────────────
# 1. Google Cloud Console → IAM & Admin → Service Accounts → Create → Keys → JSON
# 2. credentials.json ni base64 ga aylantiring:
#    PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json"))
# 3. Calendar API + Sheets API ni yoqing (APIs & Services → Library)
# 4. Kalendarni service account emailiga "Editor" sifatida ulashing
# 5. Spreadsheet ni service account emailiga "Editor" sifatida ulashing
# GOOGLE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50...   # base64
# GOOGLE_CALENDAR_ID=yourname@gmail.com                               # Gmail manzil yoki calendar ID (primary emas!)
# GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms      # spreadsheet ID
